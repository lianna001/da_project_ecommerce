from airflow import DAG
from airflow.operators.python import PythonOperator
from airflow.providers.snowflake.hooks.snowflake import SnowflakeHook
from datetime import datetime
import pandas as pd
import numpy as np
from sqlalchemy import text


def insert_daily_data_to_snowflake(ds, **kwargs):
    hook = SnowflakeHook(snowflake_conn_id='snowflake_conn')
    
    # 1. hook.run을 사용하면 문자열 에러 없이 바로 삭제 가능합니다.
    delete_sql = f"DELETE FROM RAW_PURCHASE_DATA WHERE purchase_date = '{ds}'"
    hook.run(delete_sql)
    print(f"{ds} 기존 데이터 삭제 완료")

    # 2. 데이터 생성
    df = pd.DataFrame({
        'purchase_id': [f'P{i:03}' for i in range(1, 6)],
        'amount': np.random.randint(1, 10, size=5) * 5000,
        'purchase_date': [ds] * 5
    })
    
    # 3. SQLAlchemy 엔진으로 적재
    engine = hook.get_sqlalchemy_engine()
    df.to_sql(
        name='RAW_PURCHASE_DATA', 
        con=engine, 
        schema='PUBLIC', 
        if_exists='append', 
        index=False
    )
    print(f"{ds} 데이터 5건 적재 완료")
    

# DAG 설정 부분
with DAG(
    dag_id='direct_snowflake_load_v3', # ID를 살짝 바꿔서 새로 인식시키세요
    start_date=datetime(2026, 3, 1),
    schedule='@daily',
    catchup=True # 과거 날짜를 자동으로 다 실행함
) as dag:

    task = PythonOperator(
        task_id='load_to_snowflake',
        python_callable=insert_daily_data_to_snowflake,
        # 핵심: {{ ds }} 템플릿을 함수 인자인 ds로 넘겨줌
        op_kwargs={'ds': '{{ ds }}'} 
    )
